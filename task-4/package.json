{
  "name": "atc-mcp-server",
  "version": "1.0.0",
  "private": true,
  "description": "AI-ready Air Traffic Control MCP server",
  "type": "module",
  "bin": {
    "atc-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "scenarios": "node --import tsx scripts/scenarios.ts",
    "strict": "node --import tsx scripts/strict.ts",
    "demo": "node --import tsx scripts/e2e-demo.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
